---
import Layout from '../layouts/Layout.astro';
---

<Layout title="CyberAi Dashboard - Real-time System Monitor">
  <main>
    <div class="dashboard-hero">
      <h1 class="neo-text-glow">📊 <span class="text-gradient">CyberAi Dashboard</span></h1>
      <p class="tagline">Real-time monitoring and control center for your AI ecosystem</p>
      <p id="session-summary" class="session-summary"></p>
      <div class="hero-actions">
        <a href="/login" class="neo-button neo-glow-primary" id="login-cta">Sign In</a>
        <button class="neo-button" id="logout-cta" hidden>Sign Out</button>
      </div>
    </div>

    <div class="auth-required neo-card neo-glow-primary neo-flash-glow" id="auth-required" hidden>
      <h2>Authentication Required</h2>
      <p>Please sign in to access user and admin dashboard controls.</p>
      <a href="/login" class="neo-button neo-glow-primary">Go to Login</a>
    </div>

    <div id="dashboard-content" hidden>
      <div class="dashboard-grid">
      <div class="neo-card status-card neo-flash-glow">
        <div class="card-header">
          <h2>System Status</h2>
          <span class="neo-status-active"></span>
        </div>
        <div class="status-items">
          <div class="status-item">
            <span class="neo-status-active"></span>
            <span>GitHub Actions: Online</span>
          </div>
          <div class="status-item">
            <span class="neo-status-active"></span>
            <span>Contracts: Deployed</span>
          </div>
          <div class="status-item">
            <span class="neo-status-active"></span>
            <span>SmartBrain: Active</span>
          </div>
        </div>
      </div>

      <div class="neo-card metric-card neo-flash-glow">
        <h3>Active Agents</h3>
        <div class="metric-value neo-text-glow">12</div>
        <p class="metric-label">Running across ecosystem</p>
      </div>

      <div class="neo-card metric-card neo-flash-glow">
        <h3>Smart Contracts</h3>
        <div class="metric-value neo-text-glow">48</div>
        <p class="metric-label">Deployed and verified</p>
      </div>

      <div class="neo-card metric-card neo-flash-glow">
        <h3>Security Audits</h3>
        <div class="metric-value neo-text-glow">156</div>
        <p class="metric-label">Completed this month</p>
      </div>

      <div class="neo-card activity-card neo-flash-glow">
        <h2>Recent Activity</h2>
        <ul class="activity-list">
          <li>
            <span class="activity-icon">✅</span>
            <span>Contract deployed to mainnet</span>
            <span class="activity-time">2 min ago</span>
          </li>
          <li>
            <span class="activity-icon">🔍</span>
            <span>Security audit completed</span>
            <span class="activity-time">5 min ago</span>
          </li>
          <li>
            <span class="activity-icon">🚀</span>
            <span>New agent initialized</span>
            <span class="activity-time">12 min ago</span>
          </li>
          <li>
            <span class="activity-icon">📊</span>
            <span>Performance metrics updated</span>
            <span class="activity-time">18 min ago</span>
          </li>
        </ul>
      </div>

      <div class="neo-card quick-actions neo-flash-glow">
        <h2>Quick Actions</h2>
        <div class="actions-grid">
          <a href="/operators" class="neo-button neo-glow-primary">Operator Console</a>
          <a href="/docs/contracts" class="neo-button">View Contracts</a>
          <a href="/smartbrain" class="neo-button">SmartBrain AI</a>
          <a href="/audit" class="neo-button">Run Audit</a>
        </div>
      </div>
    </div>

      <section class="neo-card admin-panel neo-glow-secondary neo-flash-glow" id="admin-panel" hidden>
        <h2>🛡️ Admin Dashboard</h2>
        <p class="admin-note">High-privilege controls for deployment, users, and RBAC settings.</p>
        <p class="admin-disclaimer" id="admin-disclaimer"></p>
        <div class="admin-grid">
          <div class="admin-item">
            <h3>User Management</h3>
            <p>Manage account access and user role assignments.</p>
          </div>
          <div class="admin-item">
            <h3>Deploy Controls</h3>
            <p>Manage GitHub Pages deployments and release rollbacks.</p>
          </div>
          <div class="admin-item">
            <h3>Audit Policies</h3>
            <p>Update compliance and security guardrails.</p>
          </div>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  main {
    margin: auto;
    padding: 2rem 1rem;
    max-width: 1400px;
  }

  .dashboard-hero {
    text-align: center;
    padding: 3rem 1rem 2rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin: 0 0 1rem 0;
    line-height: 1.2;
  }

  .text-gradient {
    background-image: linear-gradient(45deg, var(--neo-primary), var(--neo-accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .tagline {
    font-size: clamp(1rem, 3vw, 1.3rem);
    color: #666;
    margin: 0;
  }

  .session-summary {
    margin-top: 0.75rem;
    color: var(--neo-primary);
    font-weight: 600;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1rem;
    flex-wrap: wrap;
  }

  .hero-actions .neo-button {
    text-decoration: none;
  }

  .auth-required {
    max-width: 780px;
    margin: 0 auto 1.5rem;
    text-align: center;
  }

  .auth-required h2 {
    margin-bottom: 0.75rem;
  }

  .auth-required p {
    margin-bottom: 1.2rem;
  }

  .dashboard-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .neo-card {
    padding: 1.5rem;
  }

  .status-card {
    grid-column: span 1;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.5rem;
  }

  .card-header h2 {
    margin: 0;
    font-size: 1.3rem;
  }

  .status-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .status-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.95rem;
    color: #555;
  }

  .metric-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .metric-card h3 {
    margin: 0 0 1rem 0;
    font-size: 1.1rem;
    color: #666;
    font-weight: 600;
  }

  .metric-value {
    font-size: 3rem;
    font-weight: 800;
    color: var(--neo-primary);
    margin: 0.5rem 0;
  }

  .metric-label {
    font-size: 0.9rem;
    color: #888;
    margin: 0;
  }

  .activity-card {
    grid-column: span 2;
  }

  .activity-card h2 {
    margin: 0 0 1.5rem 0;
    font-size: 1.3rem;
  }

  .activity-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .activity-list li {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border-radius: 8px;
    transition: background var(--transition-fast);
  }

  .activity-list li:hover {
    background: var(--glass-bg);
  }

  .activity-icon {
    font-size: 1.2rem;
  }

  .activity-time {
    font-size: 0.85rem;
    color: #999;
  }

  .quick-actions {
    grid-column: span 1;
  }

  .quick-actions h2 {
    margin: 0 0 1.5rem 0;
    font-size: 1.3rem;
  }

  .actions-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .admin-panel {
    margin-top: 1.5rem;
  }

  .admin-note {
    color: #9dc8d2;
    margin: 0.4rem 0 1rem;
  }

  .admin-disclaimer {
    color: #9dc8d2;
    font-size: 0.82rem;
    margin: 0 0 1rem;
  }

  .admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .admin-item {
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    background: var(--glass-bg);
    padding: 1rem;
  }

  .admin-item h3 {
    margin: 0 0 0.5rem;
    color: var(--neo-secondary);
  }

  .admin-item p {
    margin: 0;
    color: #9dc8d2;
    font-size: 0.95rem;
  }

  .neo-button {
    display: block;
    text-align: center;
    padding: 0.75rem 1.5rem;
    text-decoration: none;
  }

  /* Mobile responsiveness */
  @media (max-width: 768px) {
    .dashboard-grid {
      grid-template-columns: 1fr;
    }

    .status-card,
    .activity-card,
    .quick-actions {
      grid-column: span 1;
    }

    .dashboard-hero {
      padding: 2rem 1rem 1.5rem;
    }
  }

  /* Tablet responsiveness */
  @media (min-width: 769px) and (max-width: 1024px) {
    .dashboard-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .activity-card {
      grid-column: span 2;
    }
  }
</style>

<script>
  const auth = window.CYBERAI_AUTH;
  if (!auth) {
    throw new Error('CyberAi auth helpers failed to initialize.');
  }

  const session = auth.readSession();
  const authRequired = document.getElementById('auth-required');
  const dashboardContent = document.getElementById('dashboard-content');
  const adminPanel = document.getElementById('admin-panel');
  const adminDisclaimer = document.getElementById('admin-disclaimer');
  const sessionSummary = document.getElementById('session-summary');
  const loginCta = document.getElementById('login-cta');
  const logoutCta = document.getElementById('logout-cta');

  if (!session?.email) {
    authRequired?.removeAttribute('hidden');
    if (sessionSummary) {
      sessionSummary.textContent = 'Signed out. Please log in.';
    }
  } else {
    dashboardContent?.removeAttribute('hidden');
    logoutCta?.removeAttribute('hidden');
    if (loginCta) {
      loginCta.textContent = 'Switch Account';
      loginCta.addEventListener('click', (event) => {
        event.preventDefault();
        window.location.href = '/login?switch=1';
      });
    }

    const role = auth.getRoleForSession(session);
    if (sessionSummary) {
      sessionSummary.textContent = `Signed in as ${session.email} (${role})`;
    }

    if (role === 'admin') {
      adminPanel?.removeAttribute('hidden');
      if (adminDisclaimer) {
        adminDisclaimer.textContent = auth.DEMO_AUTH_NOTICE;
      }

      const searchParams = new URLSearchParams(window.location.search);
      const adminSectionRequested = searchParams.get('section') === 'admin';
      if (adminSectionRequested) {
        adminPanel?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        adminPanel?.setAttribute('tabindex', '-1');
        adminPanel?.focus();
      }
    }
  }

  logoutCta?.addEventListener('click', () => {
    auth.clearSession();
    window.location.href = '/login';
  });
</script>
