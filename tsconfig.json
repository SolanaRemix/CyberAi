{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": [
    "src/**/*",
    "contracts/**/*.ts",
    "prompts/**/*.ts",
    "tools/**/*.ts",
    "config/**/*.ts",
    "cli/src/**/*.ts",
    "sdk/src/**/*.ts",
    "api/src/**/*.ts",
    "app/src/**/*"
  ],
  "exclude": ["node_modules", "dist", "build", "scripts/**/*", "tests/**/*"]
}
