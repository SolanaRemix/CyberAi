{
  "name": "cyberai",
  "version": "1.1.0",
  "description": "**CyberAi (formerly CuberAi)** - AI-Powered Smart Contract Security & Orchestration Platform",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "resolve-conflicts": "tsx scripts/SmartBrainConflictResolver.mts",
    "build": "tsc",
    "build:advanced": "bash scripts/advanced-build.sh production",
    "build:dev": "bash scripts/advanced-build.sh development",
    "build:watch": "tsc --watch",
    "build:esbuild": "node esbuild.config.js",
    "build:esbuild:watch": "node esbuild.config.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,json,yml,yaml,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,jsx,tsx,json,yml,yaml,md}\"",
    "verify-vercel-disconnect": "bash scripts/verify-vercel-disconnect.sh",
    "prettier:check": "prettier --check .",
    "prettier:write": "prettier --write .",
    "docker:build": "docker build -t cyberai:latest .",
    "docker:run": "docker run -p 3000:3000 cyberai:latest",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "clean": "rimraf dist build .cache node_modules/.cache",
    "clean:all": "npm run clean && rimraf node_modules",
    "dev:api": "tsx api/src/index.ts",
    "start:api": "tsx api/src/index.ts",
    "cli": "tsx cli/src/index.ts",
    "test:integration:stubs": "vitest run tests/integration/stubs.test.ts",
    "app:dev": "tsx app/src/main.tsx",
    "dashboard:dev": "tsx dashboard/src/main.tsx",
    "terminal": "tsx terminal/src/index.ts"
  },
  "dependencies": {
    "express": "^5.2.1",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitest/ui": "^4.1.4",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24.0.0"
  }
}
